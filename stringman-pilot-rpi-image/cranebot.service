[Unit]
Description=Cranebot Service
After=network.target can-setup.service
StartLimitIntervalSec=0

[Service]
Type=simple
Restart=always
RestartSec=1
User=pi
AmbientCapabilities=CAP_SYS_RAWIO
WorkingDirectory=/opt/robot
ExecStart=/opt/robot/env/bin/component-server
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target